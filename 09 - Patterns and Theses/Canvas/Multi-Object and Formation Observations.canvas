		{"id":"formation","type":"text","text":"## FORMATION (count unstated)","x":800,"y":-100,"width":250,"height":80,"color":"3"},
		{"id":"d58","type":"file","file":"02 - Incidents/Incident - 2020-10 D58 Range Fouler SKELETON.md","x":-500,"y":50,"width":400,"height":240,"color":"5"},
